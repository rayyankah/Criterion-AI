{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.onrender.com/api/:path*"
    },
    {
      "source": "/mcp/:path*",
      "destination": "https://your-backend-url.onrender.com/mcp/:path*"
    },
    {
      "source": "/((?!api|mcp).*)",
      "destination": "/index.html"
    }
  ]
}
