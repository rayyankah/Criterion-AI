# ═══════════════════════════════════════════════════════════════
# Criterion AI — Root .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
*.log

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
frontend/dist/
frontend/build/
*.tsbuildinfo

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Desktop.ini
